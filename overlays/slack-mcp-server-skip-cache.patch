+// LookupUserByID fetches a single user by ID and adds it to the users cache.
+func (ap *ApiProvider) LookupUserByID(ctx context.Context, userID string) (*slack.User, error) {
+	// Check cache first
+	snapshot := ap.usersSnapshot.Load()
+	if u, ok := snapshot.Users[userID]; ok {
+		return &u, nil
+	}
+
+	usersInfo, err := ap.client.GetUsersInfo(userID)
+	if err != nil {
+		return nil, fmt.Errorf("users.info failed for %s: %w", userID, err)
+	}
+	if usersInfo == nil || len(*usersInfo) == 0 {
+		return nil, fmt.Errorf("user %s not found", userID)
+	}
+
+	user := (*usersInfo)[0]
+	ap.addUserToCache(user)
+	ap.logger.Debug("User resolved via lazy lookup",
+		zap.String("user_id", userID),
+		zap.String("user_name", user.Name))
+	return &user, nil
+}
+
+func (ap *ApiProvider) addUserToCache(user slack.User) {
+	for {
+		old := ap.usersSnapshot.Load()
+		newSnapshot := &UsersCache{
+			Users:    make(map[string]slack.User, len(old.Users)+1),
+			UsersInv: make(map[string]string, len(old.UsersInv)+1),
+		}
+		for k, v := range old.Users {
+			newSnapshot.Users[k] = v
+		}
+		for k, v := range old.UsersInv {
+			newSnapshot.UsersInv[k] = v
+		}
+		newSnapshot.Users[user.ID] = user
+		newSnapshot.UsersInv[user.Name] = user.ID
+		if ap.usersSnapshot.CompareAndSwap(old, newSnapshot) {
+			ap.persistUsersCache(newSnapshot)
+			break
+		}
+	}
+}
+
+func (ap *ApiProvider) persistUsersCache(snapshot *UsersCache) {
+	users := make([]slack.User, 0, len(snapshot.Users))
+	for _, u := range snapshot.Users {
+		users = append(users, u)
+	}
+	data, err := json.MarshalIndent(users, "", "  ")
+	if err != nil {
+		ap.logger.Error("Failed to marshal users for cache", zap.Error(err))
+		return
+	}
+	if err := os.WriteFile(ap.usersCachePath, data, 0644); err != nil {
+		ap.logger.Error("Failed to write users cache",
+			zap.String("cache_file", ap.usersCachePath),
+			zap.Error(err))
+	}
+}
+
+func (ap *ApiProvider) addChannelToCache(ch Channel) {
+	for {
+		old := ap.channelsSnapshot.Load()
+		newSnapshot := &ChannelsCache{
+			Channels:    make(map[string]Channel, len(old.Channels)+1),
+			ChannelsInv: make(map[string]string, len(old.ChannelsInv)+1),
+		}
+		for k, v := range old.Channels {
+			newSnapshot.Channels[k] = v
+		}
+		for k, v := range old.ChannelsInv {
+			newSnapshot.ChannelsInv[k] = v
+		}
+		newSnapshot.Channels[ch.ID] = ch
+		newSnapshot.ChannelsInv[ch.Name] = ch.ID
+		if ap.channelsSnapshot.CompareAndSwap(old, newSnapshot) {
+			ap.persistChannelsCache(newSnapshot)
+			break
+		}
+	}
+}
