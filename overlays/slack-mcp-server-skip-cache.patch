+// LookupChannelByName searches for a single channel by name via the edge API
+// and adds it to the channels cache. Returns the channel ID if found.
+func (ap *ApiProvider) LookupChannelByName(ctx context.Context, name string) (string, error) {
+	mcpClient, ok := ap.client.(*MCPSlackClient)
+	if !ok {
+		return "", fmt.Errorf("lazy channel lookup requires MCPSlackClient")
+	}
+
+	query := strings.TrimLeft(name, "#@")
+
+	// Try edge search first
+	results, err := mcpClient.edgeClient.SearchChannels(ctx, query)
+	if err != nil {
+		ap.logger.Debug("Edge channel search error",
+			zap.String("query", query), zap.Error(err))
+	} else if len(results) > 0 {
+		for _, ch := range results {
+			if ch.Name == query || ch.NameNormalized == query {
+				mapped := mapChannel(
+					ch.ID, ch.Name, ch.NameNormalized,
+					ch.Topic.Value, ch.Purpose.Value,
+					ch.User, nil, ch.NumMembers,
+					ch.IsIM, ch.IsMpIM, ch.IsPrivate, ch.IsExtShared,
+					ap.ProvideUsersMap().Users,
+				)
+				ap.addChannelToCache(mapped)
+				ap.logger.Debug("Channel resolved via edge search",
+					zap.String("channel", name),
+					zap.String("channel_id", ch.ID))
+				return ch.ID, nil
+			}
+		}
+	}
+
+	// Fallback: search messages in the channel to discover its ID
+	ap.logger.Debug("Edge search missed, trying message search fallback",
+		zap.String("channel", name))
+	msgs, _, searchErr := ap.client.SearchContext(ctx, "in:#"+query, slack.SearchParameters{
+		Sort:          slack.DEFAULT_SEARCH_SORT,
+		SortDirection: slack.DEFAULT_SEARCH_SORT_DIR,
+		Count:         1,
+	})
+	if searchErr != nil {
+		ap.logger.Debug("Message search fallback failed",
+			zap.String("channel", name),
+			zap.Error(searchErr))
+	} else if msgs != nil && len(msgs.Matches) > 0 {
+		chID := msgs.Matches[0].Channel.ID
+		chName := msgs.Matches[0].Channel.Name
+		if chID != "" {
+			mapped := mapChannel(
+				chID, chName, chName,
+				"", "",
+				"", nil, 0,
+				false, false, false, false,
+				ap.ProvideUsersMap().Users,
+			)
+			ap.addChannelToCache(mapped)
+			ap.logger.Info("Channel resolved via message search",
+				zap.String("channel", name),
+				zap.String("channel_id", chID))
+			return chID, nil
+		}
+	} else {
+		ap.logger.Debug("Message search returned no results",
+			zap.String("channel", name))
+	}
+
+	return "", fmt.Errorf("channel %q not found", name)
+}
