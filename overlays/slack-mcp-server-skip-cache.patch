+// LoadUsersCacheFromDisk loads the users cache file without hitting the Slack API.
+func (ap *ApiProvider) LoadUsersCacheFromDisk() {
+	data, err := os.ReadFile(ap.usersCachePath)
+	if err != nil {
+		ap.logger.Info("No users cache file found, starting with empty cache",
+			zap.String("cache_file", ap.usersCachePath))
+		return
+	}
+	var cachedUsers []slack.User
+	if err := json.Unmarshal(data, &cachedUsers); err != nil || len(cachedUsers) == 0 {
+		ap.logger.Warn("Users cache invalid or empty, starting fresh",
+			zap.String("cache_file", ap.usersCachePath))
+		return
+	}
+	newSnapshot := &UsersCache{
+		Users:    make(map[string]slack.User, len(cachedUsers)),
+		UsersInv: make(map[string]string, len(cachedUsers)),
+	}
+	for _, u := range cachedUsers {
+		newSnapshot.Users[u.ID] = u
+		newSnapshot.UsersInv[u.Name] = u.ID
+	}
+	ap.usersSnapshot.Store(newSnapshot)
+	ap.logger.Info("Loaded users from disk cache (skip-cache mode)",
+		zap.Int("count", len(cachedUsers)),
+		zap.String("cache_file", ap.usersCachePath))
+}
