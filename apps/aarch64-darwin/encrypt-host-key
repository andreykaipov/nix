#!/bin/sh -e

green='\033[1;32m'
yellow='\033[1;33m'
red='\033[1;31m'
reset='\033[0m'

root="$(git rev-parse --show-toplevel 2>/dev/null || echo "$HOME/gh/nix")"

hostname="$(hostname)"
key_name="${hostname}.pem"
key_path="${root}/modules/home/ssh/keys/${key_name}"
recipient="$HOME/.config/agenix/recipient"
recipient_repo="${root}/modules/home/secrets/recipient"
secrets_dir="${SECRETS_DIR:-$HOME/gh/nix-secrets}"

if [ ! -f "${key_path}" ]; then
  printf "${red}No SSH key found at ${key_path}${reset}\n"
  echo "Run: nix run .#generate-host-key"
  exit 1
fi

# Prefer the deployed recipient, fall back to the repo copy (e.g. during bootstrap)
if [ ! -f "${recipient}" ]; then
  recipient="${recipient_repo}"
fi
if [ ! -f "${recipient}" ]; then
  printf "${red}agenix public key not found${reset}\n"
  exit 1
fi

# Ensure correct permissions on agenix identity key
agenix_key="$HOME/.config/agenix/identity"
if [ -f "${agenix_key}" ]; then
  chmod 600 "${agenix_key}"
fi

if [ ! -d "${secrets_dir}" ]; then
  printf "${yellow}nix-secrets not found at ${secrets_dir}, cloning...${reset}\n"
  git clone git@github.com:andreykaipov/nix-secrets.git "${secrets_dir}"
fi

secret_path="${secrets_dir}/ssh/${key_name}.age"

force=false
for arg in "$@"; do
  case "$arg" in -f|--force) force=true ;; esac
done

if [ -f "${secret_path}" ] && [ "$force" = false ]; then
  printf "${yellow}Secret already exists: ${secret_path}${reset}\n"
  printf "${yellow}Use --force to overwrite${reset}\n"
  exit 0
fi

# If the secret already exists, decrypt and compare to avoid unnecessary changes
if [ -f "${secret_path}" ] && [ -f "${agenix_key}" ]; then
  existing="$(nix run nixpkgs#age -- -d -i "${agenix_key}" "${secret_path}" 2>/dev/null)" || true
  if [ "$existing" = "$(cat "${key_path}")" ]; then
    printf "${green}Secret $secret already up to date${reset}\n"
    exit 0
  fi
fi

printf "${yellow}Encrypting ${key_name} into nix-secrets...${reset}\n"
mkdir -p "${secrets_dir}/ssh"
nix run nixpkgs#age -- -R "${recipient}" -o "${secret_path}" < "${key_path}"

printf "${green}Encrypted to ${secret_path}${reset}\n"

# Commit and push nix-secrets
git_config="${root}/modules/home/git/default.nix"
git_name="$(grep 'name = "' "$git_config" | head -1 | sed 's/.*name = "\(.*\)";/\1/')"
git_email="$(grep 'email = "' "$git_config" | head -1 | sed 's/.*email = "\(.*\)";/\1/')"

cd "${secrets_dir}"
git add "ssh/${key_name}.age"
git -c commit.gpgsign=false \
  -c user.name="$git_name" \
  -c user.email="$git_email" \
  commit -m "Add ${key_name}"

# Disable SSH connection reuse — stale control sockets can cause push failures
export GIT_SSH_COMMAND="ssh -o ControlMaster=no"

if git push; then
  printf "${green}Pushed to nix-secrets!${reset}\n"

  # Update flake.lock in nix repo
  echo ""
  printf "${yellow}Updating flake.lock in nix repo...${reset}\n"
  cd "${root}"
  nix flake update secrets
  printf "${green}Updated flake.lock!${reset}\n"

  echo ""
  printf "${yellow}Next steps:${reset}\n"
  echo "1. Commit the flake.lock and public key changes in the nix repo"
  echo "2. Run: nix run .#switch-home"
else
  printf "${red}Push failed.${reset}\n"
  echo ""
  printf "${yellow}Manual steps:${reset}\n"
  echo "1. Ensure your SSH key is on GitHub: https://github.com/settings/ssh/new"
  echo "2. Run: ssh-add ${root}/modules/home/ssh/keys/${key_name}"
  echo "3. Run: rm -rf ~/.cache/ssh/sockets"
  echo "4. Run: cd ${secrets_dir} && git push"
  echo "5. Run: cd ${root} && nix flake update secrets"
  echo "6. Run: nix run .#switch-home"
fi
