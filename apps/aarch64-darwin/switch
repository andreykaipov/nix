#!/bin/sh -e
# Build and switch both nix-darwin and home-manager configurations.

green='\033[1;32m'
yellow='\033[1;33m'
reset='\033[0m'

dir="$(cd "$(dirname "$0")" && pwd)"

echo
printf "${yellow}=== nix-darwin ===${reset}\n"
"$dir/switch-darwin" "$@"

echo
printf "${yellow}=== home-manager ===${reset}\n"
"$dir/switch-home" "$@"

printf "${green}All switches complete!${reset}\n"
