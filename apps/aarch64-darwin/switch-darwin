#!/bin/sh -e
# Build and apply the nix-darwin configuration (system defaults,
# homebrew, dock layout).

green='\033[1;32m'
yellow='\033[1;33m'
reset='\033[0m'

hostname="$(hostname)"

export NIXPKGS_ALLOW_UNFREE=1

darwin_rebuild() {
  if command -v darwin-rebuild >/dev/null 2>&1; then
    sudo darwin-rebuild "$@"
  else
    printf "${yellow}darwin-rebuild not in PATH, bootstrapping via nix run...${reset}\n"
    sudo nix --extra-experimental-features 'nix-command flakes' run nix-darwin -- "$@"
  fi
}

# Move away any /etc files that would conflict with nix-darwin's activation.
# This handles stale files from previous installs or the Nix installer.
for f in /etc/zshenv /etc/zshrc /etc/zprofile /etc/bashrc; do
  if [ -e "$f" ] && [ ! -L "$f" ]; then
    printf "${yellow}Moving $f to $f.before-nix-darwin${reset}\n"
    sudo mv "$f" "$f.before-nix-darwin"
  fi
done

printf "${yellow}Building and switching nix-darwin...${reset}\n"
# See https://github.com/nix-darwin/nix-darwin/issues/1457 on why we need sudo
darwin_rebuild switch --flake ".#${hostname}" "$@"
printf "${green}nix-darwin switch complete!${reset}\n"
