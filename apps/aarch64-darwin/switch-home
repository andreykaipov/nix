#!/bin/sh -e
# Build and apply the home-manager configuration
# (shell, git, ssh, tmux, neovim, packages).

green='\033[1;32m'
yellow='\033[1;33m'
reset='\033[0m'

hostname="$(hostname)"

export NIXPKGS_ALLOW_UNFREE=1

home_manager() {
  if command -v home-manager >/dev/null 2>&1; then
    home-manager "$@"
  else
    printf "${yellow}home-manager not in PATH, bootstrapping via nix run...${reset}\n"
    nix --extra-experimental-features 'nix-command flakes' run home-manager -- "$@"
  fi
}

printf "${yellow}Switching home-manager...${reset}\n"
home_manager switch --flake ".#${hostname}" "$@"
printf "${green}home-manager switch complete!${reset}\n"
