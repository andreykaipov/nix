# vim: ft=sshconfig

Match user git host github.com
    # Uses default IdentityFile from ~/.ssh/config

Host gh* *.github.net
    User andreykaipov
    IdentityFile ~/.ssh/ghbastion.pem
    ForwardAgent yes

Host *.github.net
    ProxyJump ghbastion

Host ghbastion
    HostName bastion.githubapp.com

Host ghshell
    HostName shell.service.ac4-iad.github.net

Host ghvault
    HostName vault-bastion.githubapp.com
