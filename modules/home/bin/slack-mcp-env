#!/usr/bin/env bash
# slack-mcp-env - Extract Slack credentials and configure slack-mcp-server environment.
# Usage: eval "$(slack-mcp-env)"
#
# If SLACK_MCP_XOXC_TOKEN and SLACK_MCP_XOXD_TOKEN are already set in the environment,
# extraction is skipped. Set SLACK_MCP_USER_AGENT too to skip log parsing.
set -euo pipefail

log() { echo "slack-mcp-env: $*" >&2; }

# Skip extraction if tokens are already set
if [[ -z "${SLACK_MCP_XOXC_TOKEN:-}" || -z "${SLACK_MCP_XOXD_TOKEN:-}" ]]; then
  log "SLACK_MCP_XOXC_TOKEN or SLACK_MCP_XOXD_TOKEN not set, extracting from Slack desktop app"
  SLACK="$HOME/Library/Application Support/Slack"
  if [[ ! -d "$SLACK" ]]; then
    SLACK="$HOME/Library/Containers/com.tinyspeck.slackmacgap/Data/Library/Application Support/Slack"
    log "trying container path: $SLACK"
  fi
  [[ -d "$SLACK" ]] || {
    log "error: Slack data directory not found"
    exit 1
  }
  log "using Slack data dir: $SLACK"

  # Extract tokens from LevelDB (copy to avoid lock conflicts with running Slack)
  tmpdir=$(mktemp -d) && trap 'rm -rf "$tmpdir"' EXIT
  ldb="$SLACK/Local Storage/leveldb"
  nfiles=$(ls "$ldb" 2>/dev/null | wc -l | tr -d ' ')
  log "copying $nfiles LevelDB files to $tmpdir"
  cp "$ldb"/* "$tmpdir/" 2>/dev/null || true

  log "parsing LevelDB for team tokens (nix-shell + plyvel)..."
  t0=$SECONDS
  tokens=$(nix-shell -p python312Packages.plyvel --run "python3 -c '
import plyvel,json,sys
db=plyvel.DB(sys.argv[1],create_if_missing=False)
for k,v in db:
  if b\"localConfig_v2\" in k:
    raw=v[1:]if v[:1]in(b\"\\x00\",b\"\\x01\",b\"\\x02\")else v
    text=raw.decode(\"utf-16-le\")if raw.count(0)>len(raw)//4 else raw.decode(\"utf-8\")
    s=text.find(\"{\");d=json.loads(text[s:text.rfind(\"}\")+1])
    for t in d[\"teams\"].values():print(t[\"name\"]+\"|\"+t[\"token\"]+\"|\"+t.get(\"url\",\"\"))
    break
db.close()
' '$tmpdir'")
  log "LevelDB parsing took $((SECONDS - t0))s"
  if [[ -z "$tokens" ]]; then
    log "error: no tokens found in LevelDB"
    exit 1
  fi
  nteams=$(echo "$tokens" | wc -l | tr -d ' ')
  log "found $nteams team(s):"
  while IFS='|' read -r name _ url; do
    log "  $name ($url)"
  done <<<"$tokens"

  # Decrypt xoxd cookie (AES-128-CBC, Chromium v10 format)
  # The AES key is derived from the Slack Safe Storage keychain password via PBKDF2.
  # We cache the derived key to avoid repeated keychain access. If there is no cached
  # key, the user must supply the password manually (because using the security
  # CLI may ironically trigger alerts for your security team).
  key_cache="$HOME/.cache/slack-mcp-env/cookie-key"
  if [[ -f "$key_cache" ]]; then
    key=$(cat "$key_cache")
    if [[ ${#key} -ne 32 ]]; then
      log "error: cached cookie key is ${#key} chars, expected 32 hex chars"
      log "  rm $key_cache"
      log "then re-run the setup below"
      rm "$key_cache"
    else
      log "using cached cookie key from $key_cache"
    fi
  fi
  if [[ ! -f "$key_cache" ]]; then
    log "error: no cached cookie key at $key_cache"
    log "to create it, get the Slack Safe Storage password from Keychain Access:"
    log "  1. open Keychain Access.app, search for 'Slack Safe Storage'"
    log "  2. double-click the entry, check 'Show password', copy it"
    log "  (using 'security find-generic-password' from the CLI works too but triggers CrowdStrike)"
    log "then run:"
    log "  mkdir -p ~/.cache/slack-mcp-env"
    log "  pbpaste | python3 -c 'import hashlib;p=input();print(hashlib.pbkdf2_hmac(\"sha1\",p.encode(),b\"saltysalt\",1003,dklen=16).hex())' > ~/.cache/slack-mcp-env/cookie-key"
    log "  chmod 600 ~/.cache/slack-mcp-env/cookie-key"
    exit 1
  fi
  log "reading encrypted cookie from Slack Cookies db"
  enc=$(sqlite3 "$SLACK/Cookies" "SELECT hex(substr(encrypted_value,4)) FROM cookies WHERE host_key LIKE '%slack%' AND name='d' LIMIT 1")
  [[ -n "$enc" ]] && log "encrypted cookie: ${#enc} hex chars" || {
    log "error: no 'd' cookie found in Cookies db"
    exit 1
  }
  decrypt_cookie() {
    echo "$enc" | xxd -r -p | openssl enc -aes-128-cbc -d -K "$1" -iv 20202020202020202020202020202020 -nopad |
      perl -ne 'print $1 if /(xoxd-[^\x00-\x1f]+)/'
  }
  log "attempting cookie decryption..."
  cookie=$(decrypt_cookie "$key") || true
  if [[ -z "$cookie" ]]; then
    log "cookie decryption failed -- cached key is likely stale (Slack may have been reinstalled)"
    log "delete the cache and re-derive the cookie key:"
    log "  rm $key_cache"
    log "then get the Slack Safe Storage password from Keychain Access and re-run setup"
    exit 1
  fi
  log "xoxd cookie decrypted (${#cookie} chars)"

  # Prefer workspace tokens over enterprise org tokens (.enterprise.slack.com)
  tok=""
  chosen_name=""
  while IFS='|' read -r name t u; do
    if [[ "$u" != *".enterprise.slack.com"* ]]; then
      tok="$t"
      chosen_name="$name"
    fi
  done <<<"$tokens"
  if [[ -n "$tok" ]]; then
    log "selected workspace token: $chosen_name"
  else
    chosen_name=$(echo "$tokens" | head -1 | cut -d'|' -f1)
    tok=$(echo "$tokens" | head -1 | cut -d'|' -f2)
    log "no workspace token found, falling back to first team: $chosen_name"
  fi

  echo "export SLACK_MCP_XOXC_TOKEN='$tok'"
  echo "export SLACK_MCP_XOXD_TOKEN='$cookie'"
else
  log "tokens already set in environment, skipping extraction"
fi

# Extract User-Agent from Slack's browser log if not already set
if [[ -z "${SLACK_MCP_USER_AGENT:-}" ]]; then
  SLACK="${SLACK:-$HOME/Library/Application Support/Slack}"
  log "extracting User-Agent from Slack browser logs"
  user_agent=$(printf '%s\0' "$SLACK/logs/default"/browser*.log | sort -rz | xargs -0 sed -n 's/.*"userAgent":[[:space:]]*"\([^"]*\)".*/\1/p' | tail -1)
  if [[ -z "$user_agent" ]]; then
    log "error: could not extract User-Agent from Slack logs. Is Slack running?"
    exit 1
  fi
  log "User-Agent: ${user_agent:0:80}..."
  echo "export SLACK_MCP_USER_AGENT='$user_agent'"
else
  log "SLACK_MCP_USER_AGENT already set, skipping log parsing"
fi
log "setting CUSTOM_TLS=true, ADD_MESSAGE_TOOL=true, MARK_TOOL=true"
echo "export SLACK_MCP_CUSTOM_TLS=true"
echo "export SLACK_MCP_ADD_MESSAGE_TOOL=true"
echo "export SLACK_MCP_MARK_TOOL=true"
tools=(
  conversations_history
  conversations_replies
  conversations_search_messages
  conversations_unreads
  conversations_add_message
  conversations_mark
  reactions_add
  reactions_remove
  users_search
  usergroups_list
  usergroups_me
  # channels_list           # bulk enumeration triggers anti-scraping
  # usergroups_create       # destructive write
  # usergroups_update       # destructive write
  # usergroups_users_update # destructive write
)
printf "export SLACK_MCP_ENABLED_TOOLS='%s'\n" "$(
  IFS=,
  echo "${tools[*]}"
)"
