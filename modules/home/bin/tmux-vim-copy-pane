#!/bin/sh
# Open the current pane's scrollback buffer in nvim (read-only) in a tmux popup.
# Colors are rendered via baleia.nvim (auto-triggered by BufReadPost autocmd).
# Press q or :q to close.

tmpfile=$(mktemp /tmp/tmux-pane-XXXXXX)
tmux capture-pane -p -eNJ -S - >"$tmpfile"
tmux popup -w 70% -h 70% -E "nvim '+set nonumber norelativenumber' '+normal Gzz' '$tmpfile'
rm -f '$tmpfile'"
