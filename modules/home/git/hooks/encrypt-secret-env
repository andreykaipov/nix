#!/bin/sh
#
# Git pre-commit hook for the nix repo.
#
# Finds any modules/home/shell/config/zshenv.<name> files and encrypts
# changed ones to nix-secrets/env/zshenv.<name>.age, then auto-commits
# and pushes.

set -eu

yellow='\033[1;33m'
green='\033[1;32m'
red='\033[0;31m'
reset='\033[0m'

git_root="$(git rev-parse --show-toplevel)"
config_dir="$git_root/modules/home/shell/config"
secrets_dir="${SECRETS_DIR:-$HOME/gh/nix-secrets}"
identity="$HOME/.config/agenix/agenix.pem"

# Collect zshenv.<name> files (skip plain zshenv)
env_files="$(find "$config_dir" -maxdepth 1 -name 'zshenv.*' -type f 2>/dev/null)" || true
[ -n "$env_files" ] || exit 0

needs_encrypt=false

for env_file in $env_files; do
  name="$(basename "$env_file")"
  hash_file="$secrets_dir/env/${name}.sha256"
  current_hash="$(shasum -a 256 "$env_file" | cut -d' ' -f1)"

  if [ -f "$hash_file" ] && [ "$(cat "$hash_file")" = "$current_hash" ]; then
    continue
  fi

  needs_encrypt=true
  break
done

[ "$needs_encrypt" = true ] || exit 0

# Preflight checks
if [ ! -f "$identity" ]; then
  printf "${red}pre-commit: secret env changed but identity key not found at %s${reset}\n" "$identity" >&2
  exit 1
fi

if [ ! -d "$secrets_dir" ]; then
  printf "${red}pre-commit: nix-secrets not found at %s${reset}\n" "$secrets_dir" >&2
  exit 1
fi

chmod 600 "$identity"
recipient="$(mktemp)"
trap 'rm -f "$recipient"' EXIT
ssh-keygen -y -f "$identity" > "$recipient" || {
  printf "${red}pre-commit: failed to derive recipient from identity${reset}\n" >&2
  exit 1
}

mkdir -p "$secrets_dir/env"

for env_file in $env_files; do
  name="$(basename "$env_file")"
  hash_file="$secrets_dir/env/${name}.sha256"
  current_hash="$(shasum -a 256 "$env_file" | cut -d' ' -f1)"

  if [ -f "$hash_file" ] && [ "$(cat "$hash_file")" = "$current_hash" ]; then
    continue
  fi

  age -R "$recipient" -o "$secrets_dir/env/${name}.age" < "$env_file"
  printf '%s' "$current_hash" > "$hash_file"
  git -C "$secrets_dir" add "env/${name}.age" "env/${name}.sha256"
  printf "${green}pre-commit: encrypted %s → nix-secrets/env/${name}.age${reset}\n" "$name"
done

# Auto-commit and push to nix-secrets
if ! git -C "$secrets_dir" diff --cached --quiet; then
  git -C "$secrets_dir" commit -m "update secret env files"
  git -C "$secrets_dir" push
fi
