#!/bin/sh
#
# Git pre-commit hook for the nix repo.
#
# Finds any modules/home/shell/config/zshenv.<name> files and encrypts
# changed ones to nix-secrets/env/zshenv.<name>.age, then auto-commits
# and pushes.

set -eu

info='\033[1;33mpre-commit:\033[0m'
ok='\033[1;32mpre-commit:\033[0m'
err='\033[0;31mpre-commit:\033[0m'

git_root="$(git rev-parse --show-toplevel)"
config_dir="$git_root/modules/home/shell/config"
secrets_dir="${SECRETS_DIR:-$HOME/gh/nix-secrets}"
identity="$HOME/.config/agenix/agenix.pem"

# Collect zshenv.<name> files (skip plain zshenv)
env_files="$(find "$config_dir" -maxdepth 1 -name 'zshenv.*' -type f 2>/dev/null)" || true
if [ -z "$env_files" ]; then
  printf "${info} no zshenv.* files found in %s\n" "$config_dir"
  exit 0
fi

printf "${info} found zshenv.* files: %s\n" "$(basename -a $env_files)"

needs_encrypt=false

for env_file in $env_files; do
  name="$(basename "$env_file")"
  hash_file="$secrets_dir/env/${name}.sha256"
  current_hash="$(shasum -a 256 "$env_file" | cut -d' ' -f1)"

  if [ -f "$hash_file" ] && [ "$(cat "$hash_file")" = "$current_hash" ]; then
    printf "${info} %s unchanged (hash match)\n" "$name"
    continue
  fi

  if [ ! -f "$hash_file" ]; then
    printf "${info} %s is new (no hash file at %s)\n" "$name" "$hash_file"
  else
    printf "${info} %s changed (hash mismatch)\n" "$name"
  fi
  needs_encrypt=true
done

if [ "$needs_encrypt" != true ]; then
  printf "${info} all zshenv.* files up to date, nothing to encrypt\n"
  exit 0
fi

# Preflight checks
if [ ! -f "$identity" ]; then
  printf "${err} secret env changed but identity key not found at %s\n" "$identity" >&2
  exit 1
fi

if [ ! -d "$secrets_dir" ]; then
  printf "${err} nix-secrets not found at %s\n" "$secrets_dir" >&2
  exit 1
fi

chmod 600 "$identity"
recipient="$(mktemp)"
trap 'rm -f "$recipient"' EXIT
ssh-keygen -y -f "$identity" > "$recipient" || {
  printf "${err} failed to derive recipient from identity\n" >&2
  exit 1
}

mkdir -p "$secrets_dir/env"

for env_file in $env_files; do
  name="$(basename "$env_file")"
  hash_file="$secrets_dir/env/${name}.sha256"
  current_hash="$(shasum -a 256 "$env_file" | cut -d' ' -f1)"

  if [ -f "$hash_file" ] && [ "$(cat "$hash_file")" = "$current_hash" ]; then
    continue
  fi

  printf "${info} encrypting %s → %s/env/${name}.age\n" "$name" "$secrets_dir"
  age -R "$recipient" -o "$secrets_dir/env/${name}.age" < "$env_file"
  printf '%s' "$current_hash" > "$hash_file"
  git -C "$secrets_dir" add "env/${name}.age" "env/${name}.sha256"
  printf "${ok} encrypted %s → nix-secrets/env/${name}.age\n" "$name"
done

# Auto-commit and push to nix-secrets
if ! git -C "$secrets_dir" diff --cached --quiet; then
  printf "${info} committing and pushing nix-secrets...\n"
  git -C "$secrets_dir" commit -m "update secret env files"
  git -C "$secrets_dir" push
  printf "${ok} nix-secrets pushed\n"
else
  printf "${info} nothing staged in nix-secrets, skipping push\n"
fi
