{
    "$schema": "https://opencode.ai/config.json",
    "theme": "dracula",
    "plugin": [
        "opencode-gemini-auth@latest"
    ],
    "mcp": {
        "atlassian": {
            "type": "local",
            "command": ["uvx", "mcp-atlassian"],
            "enabled": false,
            "environment": {
                "JIRA_URL": "{env:ATLASSIAN_URL}",
                "JIRA_USERNAME": "{env:ATLASSIAN_USERNAME}",
                "JIRA_API_TOKEN": "{env:ATLASSIAN_API_TOKEN}",
                "CONFLUENCE_URL": "{env:ATLASSIAN_WIKI_URL}/wiki",
                "CONFLUENCE_USERNAME": "{env:ATLASSIAN_USERNAME}",
                "CONFLUENCE_API_TOKEN": "{env:ATLASSIAN_API_TOKEN}"
            }
        }
    },
    "tools": {
        "atlassian_*": false
    },
    "provider": {
        "amazon-bedrock": {
            "options": {
                "region": "us-east-1"
            }
        },
        "google": {
            "models": {
                "gemini-2.5-flash": {
                    "options": {
                        "thinkingConfig": {
                            "thinkingBudget": 8192,
                            "includeThoughts": true
                        }
                    }
                },
                "gemini-2.5-pro": {
                    "options": {
                        "thinkingConfig": {
                            "thinkingBudget": 8192,
                            "includeThoughts": true
                        }
                    }
                },
                "gemini-3.1-pro-preview": {
                    "options": {
                        "thinkingConfig": {
                            "thinkingLevel": "high",
                            "includeThoughts": true
                        }
                    }
                },
                "gemini-3-flash-preview": {
                    "options": {
                        "thinkingConfig": {
                            "thinkingLevel": "high",
                            "includeThoughts": true
                        }
                    }
                },
                "gemini-3.1-flash-lite-preview": {
                    "options": {
                        "thinkingConfig": {
                            "thinkingLevel": "high",
                            "includeThoughts": true
                        }
                    }
                }
            }
        }
    }
}
