#!/bin/sh
# aws-sso-refresh - Silently refresh AWS SSO tokens using the OIDC refresh_token grant.
# Usage: aws-sso-refresh [--margin SECONDS]
set -eu

margin=900
while [ $# -gt 0 ]; do
  case "$1" in
    --margin) margin="$2"; shift 2 ;;
    *) echo "usage: aws-sso-refresh [--margin SECONDS]" >&2; exit 1 ;;
  esac
done

cache_dir="$HOME/.aws/sso/cache"
[ -d "$cache_dir" ] || { echo "no SSO cache directory" >&2; exit 1; }

now=$(date +%s)
refreshed=0

for f in "$cache_dir"/*.json; do
  [ -f "$f" ] || continue

  # Skip files without refresh tokens (e.g. client registration)
  jq -e '.refreshToken and .clientId and .clientSecret and .accessToken and .expiresAt' "$f" >/dev/null 2>&1 || continue

  expires_at=$(jq -r '.expiresAt' "$f")
  expires=$(date -d "$expires_at" +%s)
  remaining=$((expires - now))

  if [ "$remaining" -gt "$margin" ]; then
    echo "$(basename "$f"): valid for ${remaining}s, skipping"
    continue
  fi

  echo "$(basename "$f"): expires in ${remaining}s, refreshing..."

  region=$(jq -r '.region' "$f")
  payload=$(jq -c '{clientId, clientSecret, grantType: "refresh_token", refreshToken}' "$f")

  resp=$(curl -sf -X POST "https://oidc.${region}.amazonaws.com/token" \
    -H "Content-Type: application/json" \
    -d "$payload" 2>/dev/null) || {
    echo "  FAILED. Refresh token may be expired. Run: aws sso login" >&2
    continue
  }

  new_expiry=$(date -u -d "+$(echo "$resp" | jq -r '.expiresIn') seconds" +%Y-%m-%dT%H:%M:%SZ)

  jq --arg at "$(echo "$resp" | jq -r '.accessToken')" \
     --arg ea "$new_expiry" \
     --arg rt "$(echo "$resp" | jq -r '.refreshToken // empty')" \
     '.accessToken = $at | .expiresAt = $ea | if $rt != "" then .refreshToken = $rt else . end' \
     "$f" > "$f.tmp" && mv "$f.tmp" "$f"

  echo "  refreshed, new expiry: $new_expiry"
  refreshed=$((refreshed + 1))
done

[ "$refreshed" -gt 0 ] || echo "nothing to refresh"
