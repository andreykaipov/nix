{
    "$schema": "https://opencode.ai/config.json",
    "theme": "dracula",
    "plugin": [
        "opencode-gemini-auth@latest"
    ],
    "mcp": {
        "atlassian": {
            "enabled": false,
            "type": "local",
            "command": ["uvx", "mcp-atlassian"],
            "environment": {
                "JIRA_URL": "{env:ATLASSIAN_URL}",
                "JIRA_USERNAME": "{env:ATLASSIAN_USERNAME}",
                "JIRA_API_TOKEN": "{env:ATLASSIAN_API_TOKEN}",
                "CONFLUENCE_URL": "{env:ATLASSIAN_URL}/wiki",
                "CONFLUENCE_USERNAME": "{env:ATLASSIAN_USERNAME}",
                "CONFLUENCE_API_TOKEN": "{env:ATLASSIAN_API_TOKEN}",
                "TOOLSETS": "default"
            }
        },
        "terraform": {
            "enabled": false,
            "type": "local",
            "command": [
                "terraform-mcp-server", "stdio",
                "--toolsets=",
                "--tools=search_providers,get_provider_details,get_latest_provider_version,search_modules,get_module_details,get_latest_module_version,list_terraform_projects,list_workspaces,get_workspace_details,list_runs,get_run_details,list_variable_sets,list_workspace_variables,read_workspace_tags"
            ],
            "environment": {
                "TFE_TOKEN": "{env:TFE_TOKEN}",
                "TFE_ADDRESS": "{env:TFE_ADDRESS}"
            }
        },
        "slack": {
            "enabled": false,
            "type": "local",
            "command": ["bash", "-c", "eval \"$(slack-mcp-env)\" && exec slack-mcp-server --transport stdio"]
        },
        "argocd": {
            "enabled": false,
            "type": "local",
            "command": ["npx", "argocd-mcp@latest", "stdio"],
            "environment": {
                "ARGOCD_BASE_URL": "{env:ARGOCD_BASE_URL}",
                "ARGOCD_API_TOKEN": "{env:ARGOCD_API_TOKEN}",
                "MCP_READ_ONLY": "true"
            }
        },
        "grafana": {
            "enabled": false,
            "type": "local",
            "command": ["uvx", "mcp-grafana"]
        }
    },
    "tools": {
        "atlassian_*": false,
        "atlassian_jira_search": true,
        "atlassian_jira_get_issue": true,
        "atlassian_jira_get_project_issues": true,
        "atlassian_jira_search_fields": true,
        "atlassian_jira_get_field_options": true,
        "atlassian_jira_create_issue": true,
        "atlassian_jira_update_issue": true,
        "atlassian_jira_transition_issue": true,
        "atlassian_jira_add_comment": true,
        "atlassian_jira_edit_comment": true,
        "atlassian_confluence_search": true,
        "atlassian_confluence_get_page": true,
        "atlassian_confluence_get_page_children": true,
        "atlassian_confluence_get_page_history": true,
        "atlassian_confluence_get_page_diff": true,
        "atlassian_confluence_get_comments": true,
        "atlassian_confluence_create_page": true,
        "atlassian_confluence_update_page": true,
        "slack_channels_list": false,
        "slack_usergroups_create": false,
        "slack_usergroups_update": false,
        "slack_usergroups_users_update": false
    },
    "permission": {
        "external_directory": {
            "/nix/store/*": "allow"
        },
        "atlassian_jira_create_issue": "ask",
        "atlassian_jira_update_issue": "ask",
        "atlassian_jira_transition_issue": "ask",
        "atlassian_jira_add_comment": "ask",
        "atlassian_jira_edit_comment": "ask",
        "atlassian_confluence_create_page": "ask",
        "atlassian_confluence_update_page": "ask",
        "slack_conversations_add_message": "ask",
        "slack_conversations_mark": "ask",
        "slack_reactions_add": "ask",
        "slack_reactions_remove": "ask"
    },
    "provider": {
        "amazon-bedrock": {
            "options": {
                "region": "us-east-1"
            }
        },
        "google": {
            "models": {
                "gemini-2.5-flash": {
                    "options": {
                        "thinkingConfig": {
                            "thinkingBudget": 8192,
                            "includeThoughts": true
                        }
                    }
                },
                "gemini-2.5-pro": {
                    "options": {
                        "thinkingConfig": {
                            "thinkingBudget": 8192,
                            "includeThoughts": true
                        }
                    }
                },
                "gemini-3.1-pro-preview": {
                    "options": {
                        "thinkingConfig": {
                            "thinkingLevel": "high",
                            "includeThoughts": true
                        }
                    }
                },
                "gemini-3-flash-preview": {
                    "options": {
                        "thinkingConfig": {
                            "thinkingLevel": "high",
                            "includeThoughts": true
                        }
                    }
                },
                "gemini-3.1-flash-lite-preview": {
                    "options": {
                        "thinkingConfig": {
                            "thinkingLevel": "high",
                            "includeThoughts": true
                        }
                    }
                }
            }
        }
    }
}
